{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020"],
		"outDir": "out",
		"rootDir": ".",
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@*": ["src/*"]
		},
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"removeComments": true,
		"types": ["vscode", "node", "mocha"]
	},
	"include": ["src", "tests"],
	"exclude": ["node_modules", ".vscode-test"]
}
